#!/usr/bin/env bash
# Run common verification commands inside the resolved worktree root.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=./lib/execution-context.sh
. "${SCRIPT_DIR}/lib/execution-context.sh"

command_name="${1:-}"
shift || true

if [ -z "$command_name" ]; then
  echo "usage: worktree-command <pwd|lint|format|format-check|test> [args...]" >&2
  exit 1
fi

resolve_execution_context "$PWD"
cd "$PI_RESOLVED_WORKTREE_ROOT"

detect_package_manager() {
  if [ -f "bun.lock" ] || [ -f "bun.lockb" ]; then
    printf 'bun\n'
  elif [ -f "pnpm-lock.yaml" ]; then
    printf 'pnpm\n'
  elif [ -f "yarn.lock" ]; then
    printf 'yarn\n'
  else
    printf 'npm\n'
  fi
}

script_exists() {
  local script_name="$1"
  node -e 'const fs=require("fs");const p="package.json";if(!fs.existsSync(p)){process.exit(1)}const pkg=JSON.parse(fs.readFileSync(p,"utf8"));process.exit(pkg.scripts&&pkg.scripts[process.argv[1]]?0:1)' "$script_name"
}

run_script() {
  local script_name="$1"
  shift || true
  local package_manager
  package_manager="$(detect_package_manager)"

  case "$package_manager" in
    bun)
      bun run "$script_name" -- "$@"
      ;;
    pnpm)
      pnpm run "$script_name" -- "$@"
      ;;
    yarn)
      yarn "$script_name" "$@"
      ;;
    *)
      npm run --silent "$script_name" -- "$@"
      ;;
  esac
}

run_script_or_binary() {
  local script_name="$1"
  local binary_name="${2:-}"
  shift 2 || true
  if script_exists "$script_name"; then
    run_script "$script_name" "$@"
    return
  fi
  if [ -n "$binary_name" ] && [ -x "node_modules/.bin/$binary_name" ]; then
    "node_modules/.bin/$binary_name" "$@"
    return
  fi
  echo "No runner found for '$script_name' in $PI_RESOLVED_WORKTREE_ROOT" >&2
  exit 1
}

case "$command_name" in
  pwd)
    printf 'cwd=%s\nproject_root=%s\nworktree_root=%s\nsource=%s\n' \
      "$PI_RESOLVED_CWD" \
      "$PI_RESOLVED_PROJECT_ROOT" \
      "$PI_RESOLVED_WORKTREE_ROOT" \
      "$PI_RESOLVED_SOURCE"
    ;;
  lint)
    run_script_or_binary lint "" "$@"
    ;;
  format)
    run_script_or_binary format prettier "$@"
    ;;
  format-check)
    if script_exists "format:check"; then
      run_script "format:check" "$@"
    else
      run_script_or_binary format prettier --check "$@"
    fi
    ;;
  test)
    run_script_or_binary test "" "$@"
    ;;
  *)
    echo "Unsupported command: $command_name" >&2
    exit 1
    ;;
esac
